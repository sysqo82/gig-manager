<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="#FFFFFF"
    android:fitsSystemWindows="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Title -->
        <TextView
            android:id="@+id/titleText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Suede Tour Manager"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="#000000"
            android:gravity="center"
            android:paddingBottom="16dp" />

        <!-- Add New Gig Button -->
        <Button
            android:id="@+id/btnAddGig"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="+ Add New Gig"
            android:textSize="16sp"
            android:layout_marginBottom="16dp" />

        <!-- Venue Dropdown -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Select City:"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#000000"
            android:paddingBottom="8dp" />

        <Spinner
            android:id="@+id/venueSpinner"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="48dp"
            android:background="@android:drawable/btn_dropdown"
            android:padding="12dp" />

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="2dp"
            android:background="#CCCCCC"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="16dp" />

        <!-- Action Buttons -->
        <LinearLayout
            android:id="@+id/actionButtonsContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:visibility="gone"
            android:layout_marginBottom="16dp">

            <Button
                android:id="@+id/btnEditGig"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Edit"
                android:layout_marginEnd="8dp" />

            <Button
                android:id="@+id/btnDeleteGig"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Delete"
                android:backgroundTint="#D32F2F"
                android:layout_marginStart="8dp" />

        </LinearLayout>

        <!-- Gig Details Container -->
        <LinearLayout
            android:id="@+id/detailsContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <!-- Mark as complete checkbox -->
            <CheckBox
                android:id="@+id/checkComplete"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Mark as complete"
                android:textSize="16sp"
                android:textStyle="bold"
                android:paddingBottom="8dp" />

            <!-- Date -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Date:"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#555555"
                android:paddingTop="8dp" />
            <TextView
                android:id="@+id/dateText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="16sp"
                android:textColor="#000000"
                android:paddingBottom="12dp" />

            <!-- City & Venue -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="City &amp; Venue:"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#555555"
                android:paddingTop="8dp" />
            <TextView
                android:id="@+id/cityVenueText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="16sp"
                android:textColor="#0000EE"
                android:paddingBottom="12dp"
                android:background="?attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true" />

            <!-- Tickets With Me -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Are Tickets With Me?"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#555555"
                android:paddingTop="8dp" />
            <TextView
                android:id="@+id/ticketsWithMeText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="16sp"
                android:textColor="#000000"
                android:paddingBottom="12dp" />

            <!-- Where Tickets Are -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Where Tickets Are:"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#555555"
                android:paddingTop="8dp" />
            <TextView
                android:id="@+id/whereTicketsText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="16sp"
                android:textColor="#000000"
                android:paddingBottom="12dp" />

            <!-- Accommodation -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Accommodation:"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#555555"
                android:paddingTop="8dp" />
            <TextView
                android:id="@+id/accommodationText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="16sp"
                android:textColor="#0000EE"
                android:paddingBottom="12dp"
                android:background="?attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true" />

            <!-- Where the accommodation is booked -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Where the accommodation is booked:"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#555555"
                android:paddingTop="8dp" />
            <TextView
                android:id="@+id/whereAccomBoughtText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="16sp"
                android:textColor="#000000"
                android:paddingBottom="12dp" />

            <!-- Accommodation Dates -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Accommodation Dates:"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#555555"
                android:paddingTop="8dp" />
            <TextView
                android:id="@+id/accomDatesText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="16sp"
                android:textColor="#000000"
                android:paddingBottom="12dp" />

            <!-- Cost -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Cost + Paid/Pay Back:"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#555555"
                android:paddingTop="8dp" />
            <TextView
                android:id="@+id/costText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="16sp"
                android:textColor="#000000"
                android:paddingBottom="12dp" />

            <!-- Paid Status -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Paid?"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#555555"
                android:paddingTop="8dp" />
            <TextView
                android:id="@+id/paidText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="16sp"
                android:textColor="#000000"
                android:paddingBottom="12dp" />

            <!-- Accommodation Comments -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Accommodation Comments:"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#555555"
                android:paddingTop="8dp" />
            <TextView
                android:id="@+id/accomCommentsText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="16sp"
                android:textColor="#000000"
                android:paddingBottom="12dp" />

            <!-- Travel Details -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Travel Details:"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#555555"
                android:paddingTop="8dp" />
            <TextView
                android:id="@+id/travelDetailsText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="16sp"
                android:textColor="#000000"
                android:paddingBottom="16dp" />

        </LinearLayout>

    </LinearLayout>

</ScrollView>
