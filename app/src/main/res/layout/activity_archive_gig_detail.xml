<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="?attr/colorPrimary"
        android:elevation="4dp"
        app:titleTextColor="#FFFFFF"
        app:subtitleTextColor="#CCCCCC" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="#FFFFFF">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Completed badge -->
            <TextView
                android:id="@+id/archiveCompleteBadge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="✓ Completed"
                android:textSize="14sp"
                android:textColor="#FFFFFF"
                android:background="#4CAF50"
                android:padding="8dp"
                android:layout_marginBottom="12dp"
                android:visibility="gone" />

            <!-- Date -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Date:"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#555555"
                android:paddingTop="8dp" />
            <TextView
                android:id="@+id/archiveGigDateText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="16sp"
                android:textColor="#000000"
                android:paddingBottom="12dp" />

            <!-- City & Venue -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="City &amp; Venue:"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#555555"
                android:paddingTop="8dp" />
            <TextView
                android:id="@+id/archiveCityVenueText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="16sp"
                android:textColor="#000000"
                android:paddingBottom="12dp" />

            <!-- Tickets With Me -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Are Tickets With Me?"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#555555"
                android:paddingTop="8dp" />
            <TextView
                android:id="@+id/archiveTicketsWithMeText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="16sp"
                android:textColor="#000000"
                android:paddingBottom="12dp" />

            <!-- Where Tickets Are -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Where Tickets Are:"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#555555"
                android:paddingTop="8dp" />
            <TextView
                android:id="@+id/archiveWhereTicketsText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="16sp"
                android:textColor="#000000"
                android:paddingBottom="12dp" />

            <!-- Accommodation -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Accommodation:"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#555555"
                android:paddingTop="8dp" />
            <TextView
                android:id="@+id/archiveAccommodationText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="16sp"
                android:textColor="#000000"
                android:paddingBottom="12dp" />

            <!-- Where Accommodation Booked -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Where the accommodation is booked:"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#555555"
                android:paddingTop="8dp" />
            <TextView
                android:id="@+id/archiveWhereAccomBoughtText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="16sp"
                android:textColor="#000000"
                android:paddingBottom="12dp" />

            <!-- Accommodation Dates -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Accommodation Dates:"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#555555"
                android:paddingTop="8dp" />
            <TextView
                android:id="@+id/archiveAccomDatesText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="16sp"
                android:textColor="#000000"
                android:paddingBottom="12dp" />

            <!-- Cost -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Cost + Paid/Pay Back:"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#555555"
                android:paddingTop="8dp" />
            <TextView
                android:id="@+id/archiveCostText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="16sp"
                android:textColor="#000000"
                android:paddingBottom="12dp" />

            <!-- Paid Status -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Paid?"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#555555"
                android:paddingTop="8dp" />
            <TextView
                android:id="@+id/archivePaidText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="16sp"
                android:textColor="#000000"
                android:paddingBottom="12dp" />

            <!-- Accommodation Comments -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Accommodation Comments:"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#555555"
                android:paddingTop="8dp" />
            <TextView
                android:id="@+id/archiveAccomCommentsText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="16sp"
                android:textColor="#000000"
                android:paddingBottom="12dp" />

            <!-- Travel Details -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Travel Details:"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#555555"
                android:paddingTop="8dp" />
            <TextView
                android:id="@+id/archiveTravelDetailsText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="16sp"
                android:textColor="#000000"
                android:paddingBottom="16dp" />

            <!-- Delete gig from archive -->
            <Button
                android:id="@+id/btnDeleteArchiveGig"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Delete This Gig from Archive"
                android:backgroundTint="#F44336"
                android:textColor="#FFFFFF"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="8dp" />

        </LinearLayout>

    </ScrollView>

</LinearLayout>
