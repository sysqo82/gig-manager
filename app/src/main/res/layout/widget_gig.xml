<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="8dp"
    android:background="@android:color/darker_gray">

    <!-- Tour Name Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="6dp">

        <TextView
            android:id="@+id/widget_tour_name"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:text="Tour Name"
            android:textStyle="bold"
            android:textSize="16sp"
            android:textColor="@android:color/black"
            android:ellipsize="end"
            android:maxLines="1" />

        <ImageView
            android:id="@+id/widget_refresh_button"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_marginStart="8dp"
            android:contentDescription="Refresh widget"
            android:src="@android:drawable/ic_popup_sync"
            android:scaleType="centerInside" />

    </LinearLayout>

    <!-- Small label above the upcoming gig section -->
    <TextView
        android:id="@+id/widget_upcoming_label"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Upcoming gig:"
        android:textSize="12sp"
        android:textStyle="bold"
        android:textColor="@android:color/black"
        android:layout_marginBottom="4dp" />

    <!-- Upcoming Gig Section -->
    <LinearLayout
        android:id="@+id/widget_gig_date_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@android:color/black"
        android:padding="8dp"
        android:contentDescription="Upcoming gig details - tap to view full information">

        <!-- Gig Date -->
        <TextView
            android:id="@+id/widget_gig_date"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Loading..."
            android:textStyle="bold"
            android:textSize="18sp"
            android:textColor="@android:color/white"
            android:ellipsize="end"
            android:maxLines="1" />

        <!-- Gig Location -->
        <TextView
            android:id="@+id/widget_gig_location"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Location"
            android:textSize="14sp"
            android:textColor="#cccccc"
            android:layout_marginTop="4dp"
            android:ellipsize="end"
            android:maxLines="2" />

    </LinearLayout>

    <!-- Footer text -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Tap to view details"
        android:textSize="10sp"
        android:textColor="#000000"
        android:layout_marginTop="8dp"
        android:gravity="center" />

</LinearLayout>
