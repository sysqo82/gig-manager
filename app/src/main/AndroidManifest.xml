<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.suede.gigmanager">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.SuedeTourManager.NoActionBar">

        <!-- Login / splash entry point -->
        <activity
            android:name=".LoginActivity"
            android:exported="true"
            android:theme="@style/Theme.SuedeTourManager.Splash">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name=".MainActivity"
            android:exported="false" />
        <activity
            android:name=".GigDetailActivity"
            android:exported="false"
            android:theme="@style/Theme.SuedeTourManager.NoActionBar"
            android:parentActivityName=".MainActivity" />
        <activity
            android:name=".ArchiveViewActivity"
            android:exported="false"
            android:theme="@style/Theme.SuedeTourManager.Archive"
            android:parentActivityName=".MainActivity" />
        <activity
            android:name=".ArchiveGigDetailActivity"
            android:exported="false"
            android:theme="@style/Theme.SuedeTourManager.Archive"
            android:parentActivityName=".ArchiveViewActivity" />
        <activity
            android:name=".AccountActivity"
            android:exported="false"
            android:theme="@style/Theme.SuedeTourManager.Account"
            android:windowSoftInputMode="adjustResize" />
        <activity
            android:name=".ArtistListActivity"
            android:exported="false"
            android:theme="@style/Theme.SuedeTourManager.NoActionBar" />
        <activity
            android:name=".TourListActivity"
            android:exported="false"
            android:theme="@style/Theme.SuedeTourManager.NoActionBar"
            android:parentActivityName=".ArtistListActivity" />
        <activity
            android:name=".TourDetailActivity"
            android:exported="false"
            android:theme="@style/Theme.SuedeTourManager.NoActionBar"
            android:parentActivityName=".TourListActivity" />
    </application>

</manifest>
